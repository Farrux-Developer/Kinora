# TMDB v3 API key. Get one for free:
# 1. Sign up at https://www.themoviedb.org/signup
# 2. Go to https://www.themoviedb.org/settings/api and request an API key (Developer)
# 3. Copy the "API Key" (v3 auth) value here
TMDB_API_KEY=""

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/kinora"

# Auth.js secret — generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=""
