generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  createdAt    DateTime   @default(now())
  listItems    ListItem[]
}

enum ListType {
  WATCHLIST
  FAVORITE
}

enum MediaType {
  movie
  tv
}

/// A title saved to a user list. TMDB fields are denormalized so lists
/// render without extra API round-trips.
model ListItem {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listType    ListType
  mediaType   MediaType
  tmdbId      Int
  title       String
  posterPath  String?
  voteAverage Float     @default(0)
  releaseYear Int?
  note        String?
  rating      Int?
  createdAt   DateTime  @default(now())

  @@unique([userId, listType, mediaType, tmdbId])
  @@index([userId, listType])
}
